class Solution {
    public int minimumCost(int[] cost) {
        Arrays.sort(cost);
        int t=0;
        int ans=0;
        for(int i=cost.length-1;i>=0;i--){
            if(t==2){
              t=0;
            }else{
              ans+=cost[i];
              t+=1;
        }
        }
        return ans;
    }
}
